# =============================================================================
# ServiceOS — Environment Variables Reference
# Copy this file and fill in REPLACE_ME values before starting services.
# Values shown without REPLACE_ME are safe non-secret defaults for local dev.
# =============================================================================

# =============================================================================
# SHARED — used by multiple services
# =============================================================================

# JWT signing secret — must be the same across all services. Min 32 chars.
JWT_SECRET=REPLACE_ME_min_32_chars_use_openssl_rand_base64_32

# Confluent Cloud Kafka (production). For local dev these are not needed;
# services default to localhost:9092 with PLAINTEXT.
CONFLUENT_BOOTSTRAP_SERVERS=REPLACE_ME   # e.g. pkc-xxxxx.ap-south-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=REPLACE_ME
CONFLUENT_API_SECRET=REPLACE_ME

# =============================================================================
# AUTH SERVICE  (port 8081)
# =============================================================================

# Database — local docker default works if docker-compose is running
AUTH_DB_URL=jdbc:postgresql://localhost:5432/serviceos_auth?sslmode=disable
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres

# Redis — local docker default
REDIS_URL=redis://localhost:6379

# 2Factor.in OTP API key (required for SMS OTP in production)
TWOFACTOR_API_KEY=REPLACE_ME

# =============================================================================
# JOB SERVICE  (port 8082)
# =============================================================================

JOB_DB_URL=jdbc:postgresql://localhost:5432/serviceos_jobs?sslmode=disable
JOB_DB_USER=postgres
JOB_DB_PASSWORD=postgres

# Downstream service URLs (defaults work for local dev)
TECHNICIAN_SERVICE_URL=http://localhost:8085
AUTH_SERVICE_URL=http://localhost:8081

# =============================================================================
# PARTS SERVICE  (port 8083)
# =============================================================================

PARTS_DB_URL=jdbc:postgresql://localhost:5432/serviceos_parts?sslmode=disable
PARTS_DB_USER=postgres
PARTS_DB_PASSWORD=postgres

# Cloudinary (for part images — optional for local dev)
CLOUDINARY_URL=REPLACE_ME   # format: cloudinary://api_key:api_secret@cloud_name

# =============================================================================
# CUSTOMER SERVICE  (port 8084)
# =============================================================================

CUSTOMER_DB_URL=jdbc:postgresql://localhost:5432/serviceos_customers?sslmode=disable
CUSTOMER_DB_USER=postgres
CUSTOMER_DB_PASSWORD=postgres

# =============================================================================
# TECHNICIAN SERVICE  (port 8085)
# =============================================================================

TECHNICIAN_DB_URL=jdbc:postgresql://localhost:5432/serviceos_technicians?sslmode=disable
TECHNICIAN_DB_USER=postgres
TECHNICIAN_DB_PASSWORD=postgres

PARTS_SERVICE_URL=http://localhost:8083

# =============================================================================
# NOTIFICATION SERVICE  (port 8086)
# =============================================================================

# WhatsApp Cloud API (Meta)
WA_ACCESS_TOKEN=REPLACE_ME
WA_PHONE_NUMBER_ID=REPLACE_ME

# Fast2SMS (SMS fallback)
FAST2SMS_API_KEY=REPLACE_ME
FAST2SMS_SENDER=SVCOS          # optional, defaults to SVCOS

# Shop contact info (pre-filled for SK Electronics, Banda)
ADMIN_WHATSAPP=8960245022
SHOP_PHONE=8960245022

# =============================================================================
# PAYMENT SERVICE  (port 8087)
# =============================================================================

PAYMENT_DB_URL=jdbc:postgresql://localhost:5432/serviceos_payments?sslmode=disable
PAYMENT_DB_USER=postgres
PAYMENT_DB_PASSWORD=postgres

# Razorpay credentials
RAZORPAY_KEY_ID=REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME   # set in Razorpay dashboard → Webhooks → Secret

JOB_SERVICE_URL=http://localhost:8082

# =============================================================================
# ANALYTICS SERVICE  (port 8088)
# =============================================================================

ANALYTICS_DB_URL=jdbc:postgresql://localhost:5432/serviceos_analytics?sslmode=disable
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=postgres

# =============================================================================
# API GATEWAY  (port 8080)
# =============================================================================

# Downstream service base URLs (defaults work for local dev)
AUTH_SERVICE_URL=http://localhost:8081
JOB_SERVICE_URL=http://localhost:8082
PARTS_SERVICE_URL=http://localhost:8083
CUSTOMER_SERVICE_URL=http://localhost:8084
TECHNICIAN_SERVICE_URL=http://localhost:8085
PAYMENT_SERVICE_URL=http://localhost:8087
ANALYTICS_SERVICE_URL=http://localhost:8088

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:5173

# =============================================================================
# FRONTEND  (port 5173 in dev, served by Vercel in production)
# =============================================================================

VITE_API_BASE_URL=http://localhost:8080
VITE_SHOP_PHONE=8960245022
